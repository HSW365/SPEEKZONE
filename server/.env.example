# Copy to .env and fill in. Never commit the real .env file.

PORT=8080

# MongoDB Atlas connection string (free M0 cluster is fine to start)
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/speekzone

# Long random string — used to sign JWTs
JWT_SECRET=change_this_to_a_long_random_string

# From cloud.livekit.io — free tier includes generous monthly minutes.
# Create a project there, then Settings > Keys for these three values.
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret
LIVEKIT_WS_URL=wss://your-project.livekit.cloud

# Comma-separated list of allowed origins. Capacitor iOS apps send this origin.
CLIENT_ORIGIN=capacitor://localhost,http://localhost:5173
